generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  password      String
  dailyReportEmail String?
  // IANA timezone (e.g. "Asia/Shanghai", "America/Los_Angeles"). Used for
  // displaying timestamps and for the `agent_active_hours` guardrail.
  // Defaults to UTC; UI will offer a picker.
  timezone         String   @default("UTC")
  // Slack user id (e.g. "U01ABCDEF") — required for Slack interactive
  // approve/reject buttons to bind the action to an Adex User. Without
  // this, anyone in the Slack workspace could approve agent decisions.
  // Set via /settings → Profile.
  slackUserId      String?  @unique
  // Platform-level admin (different from org-level admin/owner). Can issue
  // invite codes + promote/demote other platform admins. Defaults to false;
  // bootstrap admin via PLATFORM_ADMIN_EMAILS env var (see auth.ts
  // isPlatformAdmin helper).
  isPlatformAdmin  Boolean  @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  platformAuths PlatformAuth[]
  campaigns     Campaign[]
  creatives     Creative[]
  reports       Report[]
  budgets       Budget[]
  memberships   OrgMembership[]
  sessions      Session[]
  invitesIssued InviteCode[] @relation("InviteCreator")
  inviteUsed    InviteCode?  @relation("InviteRedeemer")
  creativeBriefs CreativeBrief[]
}

// Invite-only registration: only platform admins can mint codes; new accounts
// must redeem one. Enforced server-side in /api/auth/register.
model InviteCode {
  id          String    @id @default(cuid())
  code        String    @unique  // human-shareable token (e.g. "INVT-ABCD-1234")
  createdBy   String                       // userId of issuing admin
  note        String?                      // optional admin memo (who is this for)
  // Optional batch label — admins issue codes in named batches like
  // "spring-2026 partner pilot" so multi-admin orgs can track ownership.
  batchLabel  String?
  expiresAt   DateTime?                    // null = never expires
  usedAt      DateTime?
  usedByUserId String?  @unique            // 1:1 — single-use
  createdAt   DateTime  @default(now())
  revokedAt   DateTime?

  creator     User  @relation("InviteCreator", fields: [createdBy], references: [id], onDelete: Cascade)
  usedBy      User? @relation("InviteRedeemer", fields: [usedByUserId], references: [id], onDelete: SetNull)

  @@index([createdBy])
  @@index([expiresAt, usedAt, revokedAt])
  @@index([batchLabel])
}

model Session {
  id         String   @id @default(cuid())
  userId     String
  tokenHash  String   @unique     // SHA-256 of the signed token's payload portion
  userAgent  String?
  ipAddress  String?
  createdAt  DateTime @default(now())
  lastSeenAt DateTime @default(now())
  expiresAt  DateTime
  revokedAt  DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

// A workspace / team. Resources (Campaign, Creative, Budget, Report,
// PlatformAuth, Asset) belong to an org. Every user has at least one
// personal org auto-created on registration.
model Organization {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  createdBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members       OrgMembership[]
  invites       OrgInvite[]
  campaigns     Campaign[]
  creatives     Creative[]
  budgets       Budget[]
  reports       Report[]
  platformAuths PlatformAuth[]
  assets        Asset[]
  auditEvents   AuditEvent[]
  webhooks      Webhook[]

  // Agent system (P10–P17)
  platformLinks     PlatformLink[]
  campaignSnapshots CampaignSnapshot[]
  decisions         Decision[]
  guardrails        Guardrail[]
  pendingApprovals  PendingApproval[]
  experiments       Experiment[]
  agentConfig       AgentConfig?

  // Multi-account: a workspace may have several ad-platform accounts under
  // the same connection (e.g. Google MCC with N customer IDs, TikTok with
  // N advertisers). The PlatformAuth row still mirrors the primary account
  // so legacy adapters/agent tools keep reading a single `accountId`.
  platformAccounts  PlatformAccount[]

  // Growth OS (P18–P21)
  promotedApps     PromotedApp[]
  conversionEvents ConversionEvent[]
  cohortSnapshots  CohortSnapshot[]
  growthMetrics    GrowthMetric[]
  creatorPartnerships CreatorPartnership[]
  appReviews          AppReview[]
  creativeBriefs      CreativeBrief[]
  creativeVariants    CreativeVariant[]
}

model Webhook {
  id               String    @id @default(cuid())
  orgId            String
  url              String
  secret           String    // HMAC signing secret
  events           String    // comma-separated list of event keys
  isActive         Boolean   @default(true)
  lastDeliveredAt  DateTime?
  lastStatusCode   Int?
  lastError        String?
  failureCount     Int       @default(0)
  createdBy        String
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  org       Organization      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  deliveries WebhookDelivery[]

  @@index([orgId])
}

// Persistent retry queue for failed webhook deliveries.
// Drained by /api/cron/webhook-retry with exponential backoff.
model WebhookDelivery {
  id              String   @id @default(cuid())
  webhookId       String
  event           String
  payload         String   // full JSON body to re-POST
  attempts        Int      @default(0)
  maxAttempts     Int      @default(5)
  nextAttemptAt   DateTime
  lastStatusCode  Int?
  lastError       String?
  succeededAt     DateTime?
  abandonedAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  webhook Webhook @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  @@index([nextAttemptAt, succeededAt, abandonedAt])
  @@index([webhookId])
}

model OrgMembership {
  id        String   @id @default(cuid())
  orgId     String
  userId    String
  role      String   // owner, admin, member
  createdAt DateTime @default(now())

  org  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([orgId, userId])
  @@index([userId])
}

model OrgInvite {
  id         String    @id @default(cuid())
  orgId      String
  email      String
  role       String    @default("member")
  tokenHash  String    @unique     // SHA-256 of the raw invite token
  invitedBy  String
  expiresAt  DateTime
  acceptedAt DateTime?
  createdAt  DateTime  @default(now())

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([email])
}

model PlatformAuth {
  id           String   @id @default(cuid())
  orgId        String
  userId       String   // creator; retained for audit
  platform     String   // google, meta, tiktok, appsflyer, adjust, seedream, seedance
  accountId    String?
  accessToken  String?
  refreshToken String?
  appId        String?
  appSecret    String?
  apiKey       String?
  extra        String?  // JSON string for additional config
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  org  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([orgId, platform])
  @@index([userId])
}

// One row per ad-platform account under a workspace. A Google MCC owning
// N customer IDs creates N rows here, all sharing the org-level
// PlatformAuth credentials. Per-account access tokens (TikTok-style) live
// on the row when they differ from the org-level token.
//
// `isPrimary` marks the account that mirrors into PlatformAuth.accountId
// so the existing single-account adapters keep working without changes.
model PlatformAccount {
  id           String   @id @default(cuid())
  orgId        String
  platform     String
  accountId    String
  displayName  String?
  isPrimary    Boolean  @default(false)
  isActive     Boolean  @default(true)
  accessToken  String?
  refreshToken String?
  extra        String?  // JSON
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, platform, accountId])
  @@index([orgId, platform, isPrimary])
}

model Campaign {
  id              String   @id @default(cuid())
  orgId           String
  userId          String   // creator
  name            String
  platform        String   // google, meta, tiktok
  status          String   @default("draft") // draft, active, paused, completed
  objective       String?  // awareness, consideration, conversion, app_install, web_conversion
  promotedAppId   String?  // → PromotedApp.id for app_install / web_conversion campaigns
  targetCountries String?  // JSON array of country codes
  targetAudience  String?  // JSON object with demographics
  targetInterests String?  // JSON array of interests
  ageMin          Int?
  ageMax          Int?
  gender          String?  // all, male, female
  platformCampaignId String? // ID from the ad platform (legacy; new code reads PlatformLink)
  startDate       DateTime?
  endDate         DateTime?
  // P10/P12 — desired vs synced state (agent / drift)
  desiredStatus   String   @default("draft")
  syncedStatus    String?
  syncedAt        DateTime?
  syncError       String?
  managedByAgent  Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  adGroups  AdGroup[]
  budgets   Budget[]
  reports   Report[]

  @@index([orgId])
  @@index([userId])
  @@index([orgId, managedByAgent])
}

model AdGroup {
  id              String   @id @default(cuid())
  campaignId      String
  name            String
  status          String   @default("draft")
  platformAdGroupId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  campaign  Campaign   @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  ads       Ad[]
}

model Ad {
  id            String   @id @default(cuid())
  adGroupId     String
  creativeId    String?
  name          String
  headline      String?
  description   String?
  callToAction  String?
  destinationUrl String?
  platformAdId  String?
  status        String   @default("draft")
  // P15 — surface platform reject reasons
  platformPolicyStatus String?  // approved, pending_review, rejected
  platformPolicyNote   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  adGroup   AdGroup   @relation(fields: [adGroupId], references: [id], onDelete: Cascade)
  creative  Creative? @relation(fields: [creativeId], references: [id])
}

model Creative {
  id          String   @id @default(cuid())
  orgId       String
  userId      String   // creator
  name        String
  type        String   // image, video
  source      String   // upload, seedream, seedance, agent
  filePath    String?
  fileUrl     String?
  prompt      String?  // AI generation prompt
  sourceRef   String?  // e.g. Cuddler scene id/URL when source=imported_scene
  tags        String?  // JSON array of creative tags (character/emotion/style/language)
  status      String   @default("ready") // generating, ready, failed
  width       Int?
  height      Int?
  duration    Int?     // for video, in seconds
  // P15 — review + platform sync metadata
  reviewStatus    String  @default("none")    // none | pending | approved | rejected
  reviewedBy      String?
  reviewedAt      DateTime?
  reviewNotes     String?
  platformAssetId String?                     // returned by uploadCreativeAsset
  platformPolicy  String?                     // policy_violation_reason from platform if any
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  org  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  ads  Ad[]

  @@index([orgId])
  @@index([userId])
  @@index([orgId, reviewStatus])
}

model Budget {
  id          String   @id @default(cuid())
  orgId       String
  userId      String   // creator
  campaignId  String?
  type        String   // daily, lifetime
  amount      Float
  currency    String   @default("USD")
  spent       Float    @default(0)
  startDate   DateTime?
  endDate     DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  org      Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user     User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  campaign Campaign?    @relation(fields: [campaignId], references: [id])

  @@index([orgId])
  @@index([userId])
}

model Report {
  id          String   @id @default(cuid())
  orgId       String
  userId      String   // creator of the sync
  campaignId  String?
  platform    String   // google, meta, tiktok, appsflyer, adjust
  // P11 — granularity dimensions
  level          String  @default("account")    // account | campaign | adgroup | ad
  campaignLinkId String?
  adGroupLinkId  String?
  adLinkId       String?
  date        DateTime
  impressions Int      @default(0)
  clicks      Int      @default(0)
  conversions Int      @default(0)
  spend       Float    @default(0)
  revenue     Float    @default(0)
  installs    Int      @default(0)
  ctr         Float    @default(0)
  cpc         Float    @default(0)
  cpa         Float    @default(0)
  roas        Float    @default(0)
  rawData     String?  // JSON string of full API response
  createdAt   DateTime @default(now())

  org      Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user     User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  campaign Campaign?    @relation(fields: [campaignId], references: [id])
  campaignLink PlatformLink? @relation("CampaignReport", fields: [campaignLinkId], references: [id], onDelete: SetNull)
  adGroupLink  PlatformLink? @relation("AdGroupReport",  fields: [adGroupLinkId],  references: [id], onDelete: SetNull)
  adLink       PlatformLink? @relation("AdReport",       fields: [adLinkId],       references: [id], onDelete: SetNull)

  @@index([orgId])
  @@index([userId])
  @@index([orgId, level, date])
  @@index([campaignLinkId, date])
}

model DailyDigest {
  id        String   @id @default(cuid())
  userId    String
  date      DateTime
  content   String   // HTML email content
  advice    String?  // AI-generated advice
  sentAt    DateTime?
  createdAt DateTime @default(now())
}

model AuditEvent {
  id         String   @id @default(cuid())
  orgId      String
  userId     String?  // null for system/cron events
  action     String   // e.g. "campaign.launch", "member.invite", "advisor.apply"
  targetType String?  // "campaign", "creative", "member", etc.
  targetId   String?
  metadata   String?  // JSON blob of extra context
  ipAddress  String?
  createdAt  DateTime @default(now())

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, createdAt])
  @@index([userId])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique       // SHA-256 of the raw token
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([userId])
}

model Asset {
  id            String   @id @default(cuid())
  orgId         String
  uploadedBy    String   // userId who contributed
  uploaderName  String?  // display name
  name          String
  type          String   // image, video, folder
  source        String   // upload, seedance2, seedream, gdrive
  fileUrl       String?  // public URL or local path
  thumbnailUrl  String?
  prompt        String?  // AI generation prompt
  referenceData String?  // JSON: reference images/videos/audio URLs
  taskId        String?  // Seedance2 task ID
  status        String   @default("ready") // pending, generating, ready, failed
  ratio         String?  // 16:9, 9:16, 1:1, etc.
  duration      Int?     // video duration in seconds
  model         String?  // AI model used
  tags          String?  // JSON array of tags
  fileSize      Int?     // bytes
  errorMessage  String?
  parentId      String?  // parent folder asset ID
  isFolder      Boolean  @default(false)
  driveFileId   String?  // Google Drive file ID for dedup
  folderPath    String?  // breadcrumb path e.g. "有为互动/素材"
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  org      Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  parent   Asset?  @relation("AssetTree", fields: [parentId], references: [id])
  children Asset[] @relation("AssetTree")

  @@index([orgId])
}

// =====================================================================
// Agent system (Phases 10–17)
// =====================================================================

// Per-cron rotatable secret. Replaces the single shared CRON_SECRET env
// var: each cron path gets its own token with independent rotation, audit,
// and revocation. The legacy env var still works as a fallback so the
// switchover is non-breaking.
model CronSecret {
  id          String    @id @default(cuid())
  cronPath    String    @unique             // e.g. "agent", "agent-expire"
  tokenHash   String                        // SHA-256 of the issued token
  description String?
  createdBy   String?
  createdAt   DateTime  @default(now())
  rotatedAt   DateTime?
  lastUsedAt  DateTime?
  isActive    Boolean   @default(true)

  @@index([isActive])
}

// P10 — single source of truth for "local entity ↔ platform entity" mapping
model PlatformLink {
  id               String   @id @default(cuid())
  orgId            String
  platform         String   // google, meta, tiktok, amazon, linkedin
  accountId        String   // platform account id (Google customerId, Meta act_xxx, etc.)
  entityType       String   // campaign, adgroup, ad, creative
  localEntityId    String   // PK in our table (Campaign.id, AdGroup.id, ...)
  platformEntityId String   // PK on the platform
  status           String   @default("active") // active, deleted, orphan
  lastSyncedAt     DateTime?
  metadata         String?  // JSON
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  org       Organization        @relation(fields: [orgId], references: [id], onDelete: Cascade)
  snapshots CampaignSnapshot[]
  reportsAsCampaign Report[]    @relation("CampaignReport")
  reportsAsAdGroup  Report[]    @relation("AdGroupReport")
  reportsAsAd       Report[]    @relation("AdReport")
  decisionSteps     DecisionStep[]

  @@unique([platform, accountId, platformEntityId, entityType])
  @@index([orgId, entityType, localEntityId])
  @@index([orgId, platform, status])
}

// P12 — periodic snapshot of platform-side state (for drift + rollback)
model CampaignSnapshot {
  id             String   @id @default(cuid())
  orgId          String
  platformLinkId String
  capturedAt     DateTime @default(now())
  status         String   // active, paused, removed, ...
  dailyBudget    Float?
  lifetimeBudget Float?
  bidStrategy    String?
  targeting      String?  // JSON
  raw            String   // full JSON

  org          Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  platformLink PlatformLink @relation(fields: [platformLinkId], references: [id], onDelete: Cascade)

  @@index([platformLinkId, capturedAt])
  @@index([orgId, capturedAt])
}

// P13 — agent decision records (one per LLM plan() call)
model Decision {
  id              String   @id @default(cuid())
  orgId           String
  triggerType     String   // cron, manual, webhook
  perceiveContext String   // JSON: summary fed to the LLM
  promptVersion   String?  // PromptVersion.id (P17)
  llmRequestId    String?
  llmInputTokens  Int?
  llmOutputTokens Int?
  llmCostUsd      Float?
  rationale       String   // LLM's free-form reason
  severity        String   // info, opportunity, warning, alert
  mode            String   @default("shadow") // shadow, approval_only, autonomous
  status          String   @default("pending") // pending, approved, rejected, executing, executed, failed, rolled_back, skipped
  requiresApproval Boolean @default(false)
  approvedBy      String?
  approvedAt      DateTime?
  rejectedReason  String?
  createdAt       DateTime @default(now())
  executedAt      DateTime?

  org      Organization     @relation(fields: [orgId], references: [id], onDelete: Cascade)
  steps    DecisionStep[]
  outcome  DecisionOutcome?
  approval PendingApproval?

  @@index([orgId, createdAt])
  @@index([orgId, status])
  @@index([status])
}

model DecisionStep {
  id               String   @id @default(cuid())
  decisionId       String
  stepIndex        Int
  toolName         String
  toolInput        String   // JSON
  toolOutput       String?  // JSON or error
  status           String   // pending, executed, failed, skipped, rolled_back
  guardrailReport  String?  // JSON of evaluator results
  platformResponse String?  // raw platform response (sanitized)
  platformLinkId   String?  // optional: which entity this step touched
  reversible       Boolean  @default(false)
  rollbackOf       String?  // DecisionStep.id this step rolls back, if any
  executedAt       DateTime?
  createdAt        DateTime @default(now())

  decision     Decision      @relation(fields: [decisionId], references: [id], onDelete: Cascade)
  platformLink PlatformLink? @relation(fields: [platformLinkId], references: [id], onDelete: SetNull)

  @@index([decisionId, stepIndex])
  @@index([toolName, status])
}

model DecisionOutcome {
  id             String   @id @default(cuid())
  decisionId     String   @unique
  measuredAt     DateTime
  windowHours    Int      // 24 or 168
  metricsBefore  String   // JSON baseline
  metricsAfter   String   // JSON
  delta          String   // JSON
  classification String   // success, neutral, regression, false_positive
  notes          String?
  createdAt      DateTime @default(now())

  decision Decision @relation(fields: [decisionId], references: [id], onDelete: Cascade)
}

// P14 — guardrail rules (per-org, scope-aware)
model Guardrail {
  id        String   @id @default(cuid())
  orgId     String
  scope     String   // global, platform, campaign
  scopeId   String?  // platform name or campaign id; null when scope=global
  rule      String   // budget_max_daily, budget_change_pct, status_change, ...
  config    String   // JSON: { max: 500, currency: "USD" }, etc.
  isActive  Boolean  @default(true)
  createdBy String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, scope, scopeId])
  @@index([orgId, rule, isActive])
}

// P14 — pending human approvals
model PendingApproval {
  id          String   @id @default(cuid())
  orgId       String
  decisionId  String   @unique
  notifiedAt  DateTime?
  notifiedVia String?  // email, slack, webhook
  expiresAt   DateTime
  createdAt   DateTime @default(now())

  org      Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  decision Decision     @relation(fields: [decisionId], references: [id], onDelete: Cascade)

  @@index([orgId, expiresAt])
}

// P14/P16 — agent kill switch + per-org runtime config + onboarding state
model AgentConfig {
  id              String   @id @default(cuid())
  orgId           String   @unique
  enabled         Boolean  @default(false)
  mode            String   @default("shadow") // shadow, approval_only, autonomous
  killSwitch      Boolean  @default(false)    // when true, all agent work skipped immediately
  killSwitchReason String?
  killSwitchAt    DateTime?
  monthlyLlmBudgetUsd Float @default(50)
  monthlyLlmSpentUsd  Float @default(0)
  budgetResetAt   DateTime?
  // P16 — autonomous allowlist (extra gate beyond mode=autonomous)
  autonomousAllowed   Boolean   @default(false)
  autonomousAllowedAt DateTime?
  autonomousAllowedBy String?
  // P16 — onboarding milestones (the runtime enforces minimum dwell time per stage)
  shadowStartedAt        DateTime?
  approvalOnlyStartedAt  DateTime?
  autonomousStartedAt    DateTime?
  updatedBy       String?
  updatedAt       DateTime @updatedAt
  createdAt       DateTime @default(now())

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
}

// P15 — A/B experiments
model Experiment {
  id              String   @id @default(cuid())
  orgId           String
  campaignLinkId  String   // platform campaign under test
  hypothesis      String
  status          String   @default("running") // running, completed, aborted
  startedAt       DateTime
  endsAt          DateTime
  primaryMetric   String   // ctr, roas, cpa
  minSampleSize   Int      @default(1000)
  result          String?  // JSON: winner + significance
  createdAt       DateTime @default(now())

  org  Organization    @relation(fields: [orgId], references: [id], onDelete: Cascade)
  arms ExperimentArm[]

  @@index([orgId, status])
}

model ExperimentArm {
  id              String   @id @default(cuid())
  experimentId    String
  name            String   // control, variant_a, ...
  adLinkId        String   // PlatformLink (entityType=ad)
  trafficShare    Float    // 0–1
  metricsSnapshot String?  // JSON

  experiment Experiment @relation(fields: [experimentId], references: [id], onDelete: Cascade)

  @@index([experimentId])
}

// P17 — prompt versioning + per-call accounting
model PromptVersion {
  id        String   @id @default(cuid())
  name      String   // "agent.plan", "advisor.summary", ...
  version   Int
  template  String   // full prompt text
  model     String   // claude-sonnet-4-5, etc.
  isDefault Boolean  @default(false)
  // P17 — A/B traffic split (orgId hash → default vs experimental)
  isExperimental Boolean @default(false)
  experimentalSharePct Int @default(0)  // 0..100; how many orgs get this version
  createdAt DateTime @default(now())

  runs PromptRun[]

  @@unique([name, version])
  @@index([name, isDefault])
  @@index([name, isExperimental])
}

model PromptRun {
  id              String   @id @default(cuid())
  promptVersionId String
  decisionId      String?
  inputHash       String   // SHA-256 for cache analytics
  inputTokens     Int
  outputTokens    Int
  latencyMs       Int
  costUsd         Float?
  rawOutput       String
  parsed          Boolean
  createdAt       DateTime @default(now())

  promptVersion PromptVersion @relation(fields: [promptVersionId], references: [id], onDelete: Cascade)

  @@index([promptVersionId, createdAt])
  @@index([decisionId])
}

// ─────────────────────────────────────────────────────────────────────
// Growth OS (P18–P21) — see docs/growth/00-cuddler-first-redesign.md §4
// P18 foundation: the four models below. Creator*/AppReview land in P19.
// ─────────────────────────────────────────────────────────────────────

// An app being promoted (Cuddler iOS = first row). Ad campaigns with
// objective=app_install point at one of these via Campaign.promotedAppId.
model PromotedApp {
  id             String   @id @default(cuid())
  orgId          String
  name           String
  platform       String   // ios | android | web
  bundleId       String?  // e.g. com.cuddler.main
  storeId        String?  // App Store Connect id / Play package
  deepLinkDomain String?  // e.g. cuddler.ai
  skanEnabled    Boolean  @default(true)
  extra          String?  // JSON: ASA org id, etc.
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, platform, bundleId])
  @@index([orgId])
}

// Normalized conversion event from GA4 / RevenueCat / deeplink / MMP. The
// measurement spine of the growth funnel; the unique key de-dupes on ingest.
model ConversionEvent {
  id          String   @id @default(cuid())
  orgId       String
  appId       String?  // -> PromotedApp.id (soft ref)
  source      String   // ga4 | revenuecat | deeplink | adjust
  eventName   String   // install | signup | first_chat | scene_generated | trial_start | subscription_activated | renewal | churn
  occurredAt  DateTime
  userKey     String?  // pseudonymized GA4 id / RC app_user_id
  utmSource   String?
  utmCampaign String?
  channel     String?  // paid_meta_web | paid_asa | kol | organic | ...
  country     String?
  revenue     Float    @default(0) // net revenue for subscription events
  raw         String?  // JSON
  createdAt   DateTime @default(now())

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, source, eventName, userKey, occurredAt])
  @@index([orgId, eventName, occurredAt])
  @@index([orgId, channel, occurredAt])
  @@index([appId])
}

// Per-acquisition-day x channel cohort snapshot, recomputed daily over a
// rolling 60-day window by the growth-sync cron. LTV via kpi-canon.
model CohortSnapshot {
  id            String   @id @default(cuid())
  orgId         String
  appId         String?
  cohortDate    DateTime // acquisition day
  channel       String
  computedAt    DateTime @default(now())
  installs      Int      @default(0)
  activated     Int      @default(0) // first_chat completed
  d1Retained    Int      @default(0)
  d7Retained    Int      @default(0)
  trials        Int      @default(0)
  subscribers   Int      @default(0)
  revenueToDate Float    @default(0)
  ltvEstimate   Float    @default(0)
  cac           Float?   // paid channels: spend / installs

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, appId, cohortDate, channel])
  @@index([orgId, cohortDate])
}

// Non-cohort growth metric (k-factor, weekly shares, ASO rank, ...).
model GrowthMetric {
  id        String   @id @default(cuid())
  orgId     String
  date      DateTime
  metric    String   // k_factor | weekly_scene_shares | aso_keyword_rank | ...
  channel   String?
  value     Float
  dims      String?  // JSON extra dimensions
  createdAt DateTime @default(now())

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, date, metric, channel])
  @@index([orgId, date])
}

// ─────────────────────────────────────────────────────────────────────
// Growth OS (P19) — organic attribution: KOL partnerships + app reviews
// ─────────────────────────────────────────────────────────────────────

// A creator/KOL cooperation (model + attribution method from hakko-kol-agent).
model CreatorPartnership {
  id           String   @id @default(cuid())
  orgId        String
  name         String
  platform     String   // tiktok | youtube | discord | reddit | x
  handle       String?
  status       String   @default("negotiating") // negotiating|agreed|published|settled|dropped
  costUsd      Float    @default(0) // cash + valued perks (e.g. comped Ultra)
  contractNote String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  org   Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  posts CreatorPost[]

  @@index([orgId, status])
}

model CreatorPost {
  id            String    @id @default(cuid())
  partnershipId String
  url           String
  publishedAt   DateTime?
  views         Int       @default(0)
  likes         Int       @default(0)
  comments      Int       @default(0)
  // Natural-uplift attribution: installs above the pre-publish baseline.
  baselineInstalls Float  @default(0)
  upliftInstalls   Float  @default(0)
  effectiveCpi     Float?
  lastSyncedAt  DateTime?
  createdAt     DateTime  @default(now())

  partnership CreatorPartnership @relation(fields: [partnershipId], references: [id], onDelete: Cascade)

  @@index([partnershipId])
}

// App store review + LLM classification (prompt ported from Feedback_agent).
// id = source:review_id hash → naturally idempotent on re-ingest.
model AppReview {
  id         String   @id
  orgId      String
  appId      String?
  source     String   // app_store | google_play
  country    String?
  rating     Int?
  title      String?
  body       String?
  reviewedAt DateTime
  sentiment  String?  // positive | neutral | negative | mixed
  topics     String?  // JSON array
  priority   String?  // P0..P3
  createdAt  DateTime @default(now())

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, sentiment, reviewedAt])
  @@index([orgId, reviewedAt])
}

// ─────────────────────────────────────────────────────────────────────
// Creative Studio (P20) — DCO-style creative production. A brief fans out
// into a variant matrix (platform × format × hook × language); each variant
// carries fitted copy + a produced Creative + platform-spec conformance.
// Aligned with the IAB Dynamic Content Ads schema (base + swappable slots).
// ─────────────────────────────────────────────────────────────────────

model CreativeBrief {
  id            String   @id @default(cuid())
  orgId         String
  userId        String
  name          String
  promotedAppId String?
  product       String   // what's being promoted
  audience      String?  // persona / segment
  angle         String?  // messaging angle
  platforms     String   // JSON array: [meta, tiktok, asa, google]
  languages     String?  // JSON array (default ["en"])
  status        String   @default("draft") // draft | generating | ready
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  org      Organization      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user     User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  variants CreativeVariant[]

  @@index([orgId])
}

model CreativeVariant {
  id          String   @id @default(cuid())
  briefId     String
  orgId       String
  platform    String   // meta | tiktok | asa | google
  format      String   // reels_9x16 | feed_1x1 | in_feed_9x16 | search
  hook        String?  // hook concept label
  language    String   @default("en")
  headline    String?
  primaryText String?
  cta         String?
  creativeId  String?  // → Creative (produced asset)
  specStatus  String   @default("pending") // pending | conforms | needs_transcode | rejected
  specNotes   String?
  createdAt   DateTime @default(now())

  brief CreativeBrief @relation(fields: [briefId], references: [id], onDelete: Cascade)
  org   Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([briefId])
  @@index([orgId])
}
